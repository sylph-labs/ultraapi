{
  "components": {
    "schemas": {
      "ApiError": {
        "description": "Standard API error response",
        "properties": {
          "details": {
            "description": "Validation error details",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "error": {
            "description": "Error message",
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "AuthContextResponse": {
        "properties": {
          "internal_note": {
            "type": "string"
          },
          "session_present": {
            "type": "boolean"
          },
          "user_id": {
            "type": "integer"
          }
        },
        "required": [
          "internal_note",
          "session_present",
          "user_id"
        ],
        "type": "object"
      },
      "CreateItem": {
        "properties": {
          "code": {
            "pattern": "^[A-Z]{3}$",
            "type": "string"
          },
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "minimum": 0.0,
            "type": "number"
          }
        },
        "required": [
          "code",
          "name",
          "price"
        ],
        "type": "object"
      },
      "HTTPValidationError": {
        "description": "Validation error response",
        "properties": {
          "detail": {
            "description": "Validation errors",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array"
          }
        },
        "required": [
          "detail"
        ],
        "type": "object"
      },
      "Item": {
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "name",
          "price"
        ],
        "type": "object"
      },
      "OptionalProfile": {
        "properties": {
          "bio": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "display_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "UpdateItem": {
        "properties": {
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object"
      },
      "ValidationError": {
        "description": "Validation error item",
        "properties": {
          "loc": {
            "description": "Error location",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "msg": {
            "description": "Error message",
            "type": "string"
          },
          "type": {
            "description": "Error type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Parity Test API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/items": {
      "get": {
        "description": "List items with pagination (query parameters)",
        "operationId": "list_items",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Bad Request"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Failed"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "summary": "list items",
        "tags": [
          "items"
        ]
      },
      "post": {
        "description": "Create new item (request body with validation)",
        "operationId": "create_item",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItem"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            },
            "description": "Created"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Bad Request"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Failed"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "summary": "create item",
        "tags": [
          "items"
        ]
      }
    },
